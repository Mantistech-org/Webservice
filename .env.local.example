# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe plan upfront price IDs (one-time payments)
STRIPE_PRICE_STARTER_UPFRONT=price_your-starter-upfront-id
STRIPE_PRICE_MID_UPFRONT=price_your-mid-upfront-id
STRIPE_PRICE_PRO_UPFRONT=price_your-pro-upfront-id

# Stripe plan monthly subscription price IDs
STRIPE_PRICE_STARTER_MONTHLY=price_your-starter-monthly-id
STRIPE_PRICE_MID_MONTHLY=price_your-mid-monthly-id
STRIPE_PRICE_PRO_MONTHLY=price_your-pro-monthly-id

# Stripe addon monthly subscription price IDs
STRIPE_PRICE_ADDON_REVIEW_MANAGEMENT=price_your-review-management-id
STRIPE_PRICE_ADDON_SOCIAL_MEDIA=price_your-social-media-id
STRIPE_PRICE_ADDON_LEAD_GENERATION=price_your-lead-generation-id
STRIPE_PRICE_ADDON_SEO_OPTIMIZATION=price_your-seo-optimization-id
STRIPE_PRICE_ADDON_ECOMMERCE=price_your-ecommerce-id
STRIPE_PRICE_ADDON_AD_CREATIVE=price_your-ad-creative-id
STRIPE_PRICE_ADDON_CHATBOT=price_your-chatbot-id
STRIPE_PRICE_ADDON_EMAIL_MARKETING=price_your-email-marketing-id
STRIPE_PRICE_ADDON_EMAIL_DOMAIN=price_your-email-domain-id

# Resend (email)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=onboarding@resend.dev
ADMIN_EMAIL=your@email.com

# Admin dashboard password
ADMIN_PASSWORD=supersecretpassword

# Public base URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Google Places API (for admin Lead Generation)
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Cron secret (for /api/admin/leads/process-campaigns and /api/cron/generate-blog — used by Vercel Cron or external scheduler)
CRON_SECRET=your-cron-secret

# Google Search Console (SEO Tools dashboard)
# Value should be the full JSON string of a Google service account key file.
# The service account must be added to Search Console as a verified owner or full user.
# Scope used: https://www.googleapis.com/auth/webmasters (read + sitemap submission)
GOOGLE_SEARCH_CONSOLE_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
